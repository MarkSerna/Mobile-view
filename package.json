{
  "name": "mobile-view",
  "displayName": "Mobile View",
  "description": "Preview web apps inside iPhone and Android sized Chromium webviews from Visual Studio Code.",
  "version": "0.1.3",
  "publisher": "MarkSerna",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MarkSerna/Mobile-view.git"
  },
  "homepage": "https://github.com/MarkSerna/Mobile-view#readme",
  "bugs": {
    "url": "https://github.com/MarkSerna/Mobile-view/issues"
  },
  "keywords": [
    "mobile",
    "preview",
    "webview",
    "responsive",
    "iphone",
    "android",
    "testing"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Testing"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mobileView.open",
        "title": "Mobile View: Open Preview",
        "category": "Mobile View"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mobileViewSidebar",
          "title": "Mobile View",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "mobileViewSidebar": [
        {
          "id": "mobileView.sidebarView",
          "name": "Mobile View Simulator",
          "type": "webview",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Mobile View",
      "properties": {
        "mobileView.defaultUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Default URL opened by Mobile View."
        }
      }
    }
  },
  "scripts": {
    "lint": "node --check src/extension.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.32.0"
  }
}
